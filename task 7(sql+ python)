    "import sqlite3\n",
    "\n",
    "# Create database and connect\n",
    "conn = sqlite3.connect(\"sales_data.db\")\n",
    "cursor = conn.cursor()\n",
    "\n",
    "# Create table\n",
    "cursor.execute(\"\"\"\n",
    "CREATE TABLE IF NOT EXISTS sales (\n",
    "    product TEXT,\n",
    "    quantity INTEGER,\n",
    "    price REAL\n",
    ")\n",
    "\"\"\")\n",
    "\n",
    "# Insert sample data\n",
    "cursor.execute(\"INSERT INTO sales VALUES ('Laptop', 5, 50000)\")\n",
    "cursor.execute(\"INSERT INTO sales VALUES ('Mobile', 10, 20000)\")\n",
    "cursor.execute(\"INSERT INTO sales VALUES ('Tablet', 7, 15000)\")\n",
    "cursor.execute(\"INSERT INTO sales VALUES ('Laptop', 3, 50000)\")\n",
    "cursor.execute(\"INSERT INTO sales VALUES ('Mobile', 5, 20000)\")\n",
    "\n",
    "conn.commit()\n",
    "\n",
    "print(\"Database and table created successfully!\")\n"
   ]
  },
